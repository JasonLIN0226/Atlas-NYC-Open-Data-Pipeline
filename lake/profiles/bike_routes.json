        "position": 1
      },
      {
        "name": "segmentid",
        "field_name": "segmentid",
        "description": "From LION 23C. A number of up to seven digits that identifies each segment of a street or a non-street feature represented in the LION file. Nonstandard Segment IDs reflect a difference in geometry from LION 23C and existing conditions.",
